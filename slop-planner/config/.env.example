# Cline CLI Configuration

# LM Studio API endpoint (for Docker host access)
# Replace with your local LM Studio server URL if different
CLINE_API_BASE_URL=http://host.docker.internal:1234/v1

# Default model identifier (user can override in prompts)
# Examples: llama3.1:70b, gemma-2:9b, mistral:7b
CLINE_MODEL=llama3.1:70b
GITHUB_TOKEN=

# Host workspace path (absolute path to your project directory)
WORKSPACE_PATH=/home/brajam/repos/slop-generator
