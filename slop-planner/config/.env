# =============================================================================
# Cline CLI Configuration
# Loaded into the container via env_file in docker-compose.yml.
# These values are read at runtime by agent-runner.js and git-sync.js.
# =============================================================================

# Which AI provider to use. "lmstudio" for local inference via LM Studio.
CLINE_PROVIDER=lmstudio

# LM Studio API endpoint (must include /v1 suffix).
CLINE_API_BASE_URL=http://192.168.0.13:1234/v1

# Model identifier loaded in LM Studio.
CLINE_MODEL=qwen/qwen3.5-9b

# Optional GitHub token for MCP server authentication.
# Leave empty if not using GitHub MCP features.
GITHUB_TOKEN=

# =============================================================================
# Git Sync Configuration
# Runs inside the agent loop — git-sync.js --once is called after each
# successful idea generation by agent-runner.js.
# =============================================================================

# Pushes after each completed iteration (per-idea, immediate).
# Called by agent-runner.js via git-sync.js --once.
# Planner pushes all apps/ to GIT_BRANCH after each idea generation.

# Remote git repo URL with embedded auth.
# Format: https://<user>:<token>@github.com/<owner>/<repo>.git
# Leave empty for local-only commits (no push).
GIT_REPO_URL=

# Git branch to push to.
GIT_BRANCH=main

# Git commit author name.
GIT_USER_NAME=Slop Generator

# Git commit author email.
GIT_USER_EMAIL=slop-generator@localhost

# When true, db.md is also tracked in git alongside apps/.
# When false (default), only the apps/ directory is tracked.
GIT_SYNC_DB=false

