# =============================================================================
# Slop Generator — Root .gitignore
# Covers all three microservices: slop-planner, slop-api, slop-builder
# =============================================================================

# ---------------------------------------------------------------------------
# Secrets — never commit
# ---------------------------------------------------------------------------
.env
*.key
*.pem
*.crt
secrets/
credentials/

# ---------------------------------------------------------------------------
# Dependencies — installed per service at build time
# ---------------------------------------------------------------------------
**/node_modules/

# ---------------------------------------------------------------------------
# Build artifacts
# ---------------------------------------------------------------------------
dist/
build/
*.tsbuildinfo
.next/
.cache/
*.pyc
__pycache__/

# ---------------------------------------------------------------------------
# slop-planner — generated idea files and database
# ---------------------------------------------------------------------------
slop-planner/apps/*
!slop-planner/apps/.gitkeep
slop-planner/db.md

# ---------------------------------------------------------------------------
# slop-api — data store (API-owned copy of ideas, generated at runtime)
# ---------------------------------------------------------------------------
slop-api/data/db.md
slop-api/data/apps/*
!slop-api/data/apps/.gitkeep

# ---------------------------------------------------------------------------
# slop-builder — built projects and database
# ---------------------------------------------------------------------------
slop-builder/projects/*
!slop-builder/projects/.gitkeep
slop-builder/db.md

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
docker-compose.override.yml
.dockerignore

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# OS noise
# ---------------------------------------------------------------------------
*.log
*.bak
*.orig
*.template.bak
